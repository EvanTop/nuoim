        <!-- Gradient mesh background -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
          <div
            class="absolute top-[-10rem] left-1/2 -translate-x-[65%] w-[52rem] h-[52rem] rounded-full"
