  box-shadow: var(--hw-shadow-md);
}

/* ── FAQ transition ── */
.faq-answer {
  max-height: 0;
  overflow: hidden;
  padding-top: 0;
  padding-bottom: 0;
  opacity: 0;
  transition: max-height 0.3s ease, padding 0.3s ease, opacity 0.25s;
}
.faq-answer.faq-open {
  max-height: 14rem;
  padding-bottom: 1.25rem;
  opacity: 1;
}

/* ── Typing cursor ── */
.typing-cursor { opacity: 1; transition: opacity 0.1s; }
.typing-cursor.blink { opacity: 0; }
