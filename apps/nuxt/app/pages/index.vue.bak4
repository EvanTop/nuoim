<style scoped>
/* ============================================
   Neo-Brutalist Theme — nuo.im Homepage
   Inspired by BlockFrame design language
   ============================================ */

/* ── CSS Variables ── */
.hw {
  --nb-pink: #FE90E8;
  --nb-blue: #C0F7FE;
  --nb-green: #99E885;
  --nb-yellow: #F7CB46;
  --nb-cream: #FFDC8B;
  --nb-purple: #7c3aed;

  --hw-bg: #FFFDF5;
  --hw-bg-card: #FFFFFF;
  --hw-bg-nav: rgba(255, 253, 245, 0.94);
  --hw-border: #000000;
  --hw-text: #000000;
  --hw-text-2: #333333;
  --hw-text-3: #555555;
  --hw-shadow-sm: 3px 3px 0px #000000;
  --hw-shadow-md: 5px 5px 0px #000000;
  --hw-shadow-lg: 8px 8px 0px #000000;
  background: var(--hw-bg);
  color: var(--hw-text);
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

